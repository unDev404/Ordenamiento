// =========================================================
//                      EL MAIN PRINCIPAL
// =========================================================
int main() {
    int opcionPrincipal = 0;

    while (opcionPrincipal != 5) {
        cout << "\n=========================================\n";
        cout << "            MENU PRINCIPAL               \n";
        cout << "=========================================\n";
        cout << "1. Ejecutar con Arreglo DESORDENADO\n";
        cout << "2. Ejecutar con Arreglo ORDENADO\n";
        cout << "3. Ejecutar con Arreglo INVERTIDO\n";
        cout << "4. Ver Ranking de mejores tiempos\n";
        cout << "5. Salir del Programa\n";
        cout << "Seleccione una opcion: ";
        cin >> opcionPrincipal;

        // Si se selecciona una de las 3 opciones de arreglos
        if (opcionPrincipal >= 1 && opcionPrincipal <= 3) {
            
            // 1. Llamada a la función para configurar el tipo de arreglo
            if (opcionPrincipal == 1) generarDesordenado();
            else if (opcionPrincipal == 2) generarOrdenado();
            else if (opcionPrincipal == 3) generarInvertido();

            // 2. Aquí se ejecutan en cadena todos tus algoritmos
            ordenarInsercion();
            ordenarSeleccion();
            ordenarBurbuja();
            ordenarBurbujaModificado();
            ordenarShellSort();
            ordenarQuickSort();
            ordenarSTL();

            cout << "\n[!] Todos los algoritmos han sido ejecutados.\n";

            // 3. Sub-menú para elegir qué tipo de métrica visualizar
            int subOpcion = 0;
            while (subOpcion != 4) {
                cout << "\n--- COMO DESEA VER LOS RESULTADOS? ---\n";
                cout << "1. Reporte por TIEMPOS\n";
                cout << "2. Reporte por COMPARACIONES\n";
                cout << "3. Reporte por INTERCAMBIOS\n";
                cout << "4. Volver al menu principal\n";
                cout << "Seleccione una opcion: ";
                cin >> subOpcion;

                if (subOpcion == 1) mostrarReporteTiempos();
                else if (subOpcion == 2) mostrarReporteComparaciones();
                else if (subOpcion == 3) mostrarReporteIntercambios();
            }
        }
        else if (opcionPrincipal == 4) {
            // 4. Llamada para ver la lista de los mejores tiempos ordenados
            mostrarRankingTiempos();
        }
    }

    cout << "\nPrograma finalizado con exito.\n";
    return 0;
}


